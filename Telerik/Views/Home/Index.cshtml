@{
    ViewBag.Title = "Inicio - GCI Sistema Industrial";
}

<div style="padding: 30px;">
    <h2 style="color: #1a5276; margin-bottom: 10px;">
        <i class="fas fa-home"></i> Bienvenido al Sistema GCI
    </h2>
    <p style="color: #666; font-size: 0.95rem;">
        Seleccione una opción del menú lateral para comenzar.
    </p>
    <hr style="border-color: #e0e0e0;" />
    <div style="background: #fff; border: 1px solid #e0e0e0; border-radius: 6px; padding: 25px; margin-top: 15px;">
        <h4 style="color: #2471a3; margin-bottom: 12px;">
            <i class="fas fa-info-circle"></i> Panel de Inicio
        </h4>
        <p style="color: #555; font-size: 0.88rem; line-height: 1.6;">
            Este es el sistema de gestión industrial de <strong>GCI Grupo Constructor Industrial Oil & Gas</strong>.
            Utilice el menú de la izquierda para navegar entre los módulos disponibles:
            RH, Nómina, Reportes, Catálogos, Asistencias, Seguridad e Higiene, Sistema, Administración y Servicio Médico.
        </p>
    </div>
</div>
