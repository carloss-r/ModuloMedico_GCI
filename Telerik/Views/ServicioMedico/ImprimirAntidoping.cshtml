@model Telerik.Models.ViewModels.AntidopingVm
@{
    Layout = null;
    var orden = ViewBag.Orden as Telerik.Models.ViewModels.OrdenServicioMedicoVm;
    var paciente = ViewBag.Paciente as Telerik.Models.ViewModels.PacienteInfoVm;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Examen Antidoping - @orden.FolioDisplay</title>
    <style>
        @@page { size: letter; margin: 10mm; }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Arial, sans-serif; font-size: 11pt; line-height: 1.4; color: #000; background: #fff; }
        .container { width: 100%; max-width: 800px; margin: 0 auto; padding: 20px; }
        
        /* Header */
        .title-container { text-align: center; margin-bottom: 20px; }
        h1 { font-size: 16pt; margin: 0; text-transform: uppercase; font-weight: bold; }
        h2 { font-size: 13pt; margin: 5px 0 0 0; font-weight: normal; text-transform: uppercase; }
        
        .divider { border-bottom: 2px solid #000; margin-top: 10px; margin-bottom: 20px; }

        /* General Table */
        table { width: 100%; border-collapse: collapse; margin-bottom: 15px; }
        
        /* Layout Table for Header Data */
        .header-table { margin-bottom: 20px; }
        .header-table td { padding: 4px 0; vertical-align: bottom; }
        .header-table .label { font-weight: bold; width: 80px; }
        .header-table .value { border-bottom: 1px solid #000; padding-left: 5px; }
        
        /* Section Title Box */
        .section-box { border: 1px solid #000; padding: 5px 10px; font-weight: bold; font-size: 11pt; background: #f0f0f0; margin-bottom: 10px; -webkit-print-color-adjust: exact; print-color-adjust: exact; }

        /* Data grids */
        .data-grid { width: 100%; display: table; margin-bottom: 20px; }
        .grid-row { display: table-row; }
        .grid-cell { display: table-cell; border: 1px solid #000; padding: 5px; text-align: center; }
        .grid-cell-title { font-weight: bold; font-size: 9pt; }
        .grid-cell-value { font-size: 11pt; padding-top: 5px; }

        /* Results table */
        .results-table th, .results-table td { border: 1px solid #000; padding: 6px; }
        .results-table th { background: #f0f0f0; font-weight: bold; -webkit-print-color-adjust: exact; print-color-adjust: exact;}

        /* Signature area */
        .signatures { display: flex; justify-content: space-between; margin-top: 60px; padding: 0 40px; }
        .signature-box { text-align: center; width: 40%; font-size: 10pt; }
        .signature-line { border-top: 1px solid #000; padding-top: 5px; margin-bottom: 5px; }

        @@media print { 
            .no-print { display: none !important; } 
            * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
        }
        
        .print-btn { position: fixed; top: 10px; right: 10px; padding: 8px 15px; background: #333; color: white; border: none; cursor: pointer; border-radius: 4px; z-index: 1000;}
    </style>
</head>
<body>
    <!-- Botón removido (Impresión externa) -->

    <div class="container">
        <div class="title-container">
            <h1>EXAMEN MÉDICO OCUPACIONAL</h1>
            <h2>ANTIDOPING</h2>
            <div class="divider"></div>
        </div>

        <table class="header-table">
            <tr>
                <td class="label">Folio:</td>
                <td class="value" style="width: 40%;">@orden.FolioDisplay</td>
                <td class="label" style="width: 60px; padding-left: 20px;">Fecha:</td>
                <td class="value">@DateTime.Now.ToString("dd/MM/yyyy")</td>
            </tr>
            <tr>
                <td class="label">Nombre:</td>
                <td class="value">@paciente.NombreCompleto</td>
                <td class="label" style="padding-left: 20px;">Edad:</td>
                <td class="value">@paciente.Edad años</td>
            </tr>
            <tr>
                <td class="label">Puesto:</td>
                <td class="value">@paciente.Puesto</td>
                <td class="label" style="padding-left: 20px;">Área:</td>
                <td class="value">@paciente.Area</td>
            </tr>
            <tr>
                <td class="label">Empresa:</td>
                <td class="value">@paciente.Empresa</td>
                <td class="label" style="padding-left: 20px;">Sexo:</td>
                <td class="value">@(paciente.Sexo == "F" ? "Femenino" : "Masculino")</td>
            </tr>
            <tr>
                <td class="label">RFC:</td>
                <td class="value">@paciente.Rfc</td>
                <td class="label" style="padding-left: 20px;">CURP:</td>
                <td class="value">@paciente.Curp</td>
            </tr>
        </table>

        <div class="section-box">
            RESULTADOS DE DETECCIÓN DE SUSTANCIAS
        </div>

        <table class="results-table">
            <thead>
                <tr>
                    <th style="width: 50%; text-align: left;">Sustancia</th>
                    <th style="width: 25%;">Resultado</th>
                    <th style="width: 25%;">Cut-off</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Cocaína (COC)</td>
                    <td style="text-align: center; font-weight: bold;">@(Model.ResultadoCocaina ? "POSITIVO" : "NEGATIVO")</td>
                    <td style="text-align: center;">300 ng/mL</td>
                </tr>
                <tr>
                    <td>Marihuana (THC)</td>
                    <td style="text-align: center; font-weight: bold;">@(Model.ResultadoTHC ? "POSITIVO" : "NEGATIVO")</td>
                    <td style="text-align: center;">50 ng/mL</td>
                </tr>
                <tr>
                    <td>Anfetaminas (AMP)</td>
                    <td style="text-align: center; font-weight: bold;">@(Model.ResultadoAnfetaminas ? "POSITIVO" : "NEGATIVO")</td>
                    <td style="text-align: center;">1000 ng/mL</td>
                </tr>
                <tr>
                    <td>Metanfetaminas (mAMP)</td>
                    <td style="text-align: center; font-weight: bold;">@(Model.ResultadoMetanfetaminas ? "POSITIVO" : "NEGATIVO")</td>
                    <td style="text-align: center;">1000 ng/mL</td>
                </tr>
                <tr>
                    <td>Opiáceos (OPI)</td>
                    <td style="text-align: center; font-weight: bold;">@(Model.ResultadoOpiaceos ? "POSITIVO" : "NEGATIVO")</td>
                    <td style="text-align: center;">2000 ng/mL</td>
                </tr>
            </tbody>
        </table>

        <div class="section-box" style="margin-top: 20px;">
            DIAGNÓSTICO Y APTITUD MÉDICA
        </div>

        <table style="margin-bottom: 20px;">
            <tr>
                <td style="width: 80px; font-weight: bold;">Aptitud:</td>
                <td style="border-bottom: 1px solid #000; font-weight: bold; font-size: 13pt;">@Model.VeredictoFinal</td>
            </tr>
        </table>

        <div style="font-weight: bold; margin-bottom: 5px;">Observaciones:</div>
        <div style="border: 1px solid #000; min-height: 80px; padding: 10px;">
            @Model.Comentarios
        </div>
        
        @if (!string.IsNullOrEmpty(Model.UrlFotoEvidencia))
        {
            <div style="margin-top: 20px; text-align: center;" class="no-print">
                <div style="border: 1px solid #000; padding: 10px; display: inline-block;">
                    <strong style="display: block; margin-bottom: 5px;">Evidencia adjunta (no se imprime por defecto)</strong>
                    <img src="@Url.Content(Model.UrlFotoEvidencia)" alt="Evidencia" style="max-width: 300px; max-height: 200px;" />
                </div>
            </div>
        }

        <div class="signatures">
            <div class="signature-box">
                <div class="signature-line">Firma del Médico Evaluador</div>
                <div>Cédula Profesional: ______________</div>
            </div>
            <div class="signature-box">
                <div class="signature-line">Firma del Paciente</div>
                <div>Fecha: @DateTime.Now.ToString("dd/MM/yyyy")</div>
            </div>
        </div>
    </div>
</body>
</html>
