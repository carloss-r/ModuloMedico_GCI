@{
    ViewBag.Title = "Servicio Médico - Solicitudes Recibidas";
}

<style>
    .sm-container { padding: 20px 25px; min-height: 80vh; }
    .sm-header { background: #1a5276; border-radius: 6px; padding: 18px 22px; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; }
    .sm-header h2 { margin: 0; font-size: 1.3rem; color: #fff; font-weight: 600; }
    .sm-header h2 i { margin-right: 8px; }

    /* ═══ Filtros ═══ */
    .sm-filtros { background: #fff; border: 1px solid #d0d0d0; border-radius: 6px; padding: 16px 20px; margin-bottom: 20px; }
    .sm-filtros .filtros-title { font-size: 0.82rem; font-weight: 600; color: #1a5276; margin-bottom: 12px; }
    .sm-filtros .filtros-title i { margin-right: 6px; }
    .filtros-row { display: flex; gap: 14px; align-items: flex-end; }
    .filtro-group { display: flex; flex-direction: column; flex: 1; min-width: 0; }
    .filtro-group label { font-size: 0.72rem; font-weight: 600; color: #666; margin-bottom: 3px; text-transform: uppercase; letter-spacing: 0.3px; }
    .filtro-group input, .filtro-group select {
        padding: 7px 10px; border: 1px solid #d0d0d0; border-radius: 4px;
        font-size: 0.82rem; font-family: inherit; outline: none; transition: border-color 0.2s;
        width: 100%; box-sizing: border-box;
    }
    .filtro-group input:focus, .filtro-group select:focus { border-color: #2471a3; }
    .filtro-group select { width: 100%; }
    .btn-filtrar { padding: 7px 16px; background: #2471a3; color: #fff; border: none; border-radius: 4px; font-size: 0.8rem; font-weight: 600; cursor: pointer; font-family: inherit; }
    .btn-filtrar:hover { background: #1a5276; }
    .btn-limpiar { padding: 7px 16px; background: #f0f0f0; color: #555; border: 1px solid #d0d0d0; border-radius: 4px; font-size: 0.8rem; cursor: pointer; font-family: inherit; }
    .btn-limpiar:hover { background: #e0e0e0; }

    /* Tabla */
    .sm-panel { background: #fff; border: 1px solid #d0d0d0; border-radius: 6px; padding: 22px; margin-bottom: 20px; }
    .sm-panel .sp-title { font-size: 0.92rem; font-weight: 600; color: #1a5276; margin-bottom: 14px; display: flex; align-items: center; justify-content: space-between; }
    .sm-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
    .sm-table thead th { background: #1a5276; color: #fff; padding: 10px 12px; text-align: left; font-weight: 600; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.3px; }
    .sm-table tbody tr { border-bottom: 1px solid #eee; transition: background 0.15s; cursor: context-menu; position: relative; }
    .sm-table tbody tr:hover { background: #f5f8fc; }
    .sm-table tbody td { padding: 9px 12px; color: #333; }
    
    .badge-sm { padding: 3px 10px; border-radius: 12px; font-size: 0.72rem; font-weight: 600; color: #fff; display: inline-block; }
    .badge-periodico { background: #8e44ad; }
    .badge-ingreso { background: #16a085; }
    .badge-pendiente { background: #e67e22; }
    .badge-proceso { background: #2471a3; }
    .badge-completado { background: #27ae60; }

    .btn-gci { padding: 9px 24px; font-size: 0.85rem; font-weight: 600; border: none; border-radius: 4px; cursor: pointer; transition: all 0.2s; font-family: inherit; }
    .btn-gci-primary { background: #1a5276; color: #fff; }
    .btn-gci-primary:hover { background: #154360; }
    .btn-gci-secondary { background: #f0f0f0; color: #333; border: 1px solid #d0d0d0; }
    .btn-gci-secondary:hover { background: #e0e0e0; }
    .btn-gci-sm { padding: 5px 12px; font-size: 0.78rem; }
    .btn-gci-danger { background: #c0392b; color: #fff; }
    .btn-gci-danger:hover { background: #a93226; }

    .no-data { text-align: center; padding: 30px; color: #999; font-size: 0.9rem; }
    .resultados-info { font-size: 0.75rem; color: #888; margin-bottom: 8px; }

    /* ══════════ Botones de Acción en Tabla ══════════ */
    .row-actions { display: flex; gap: 4px; justify-content: center; }
    .row-btn { padding: 4px 10px; font-size: 0.72rem; font-weight: 600; border: none; border-radius: 3px; cursor: pointer; font-family: inherit; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; transition: all 0.15s; }
    .row-btn-ver { background: #2471a3; color: #fff; }
    .row-btn-ver:hover { background: #1a5276; color: #fff; }
    .row-btn-eval { background: #16a085; color: #fff; }
    .row-btn-eval:hover { background: #0e8c73; color: #fff; }

    /* ══════════ Modal Detalle ══════════ */
    .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.45); z-index: 3000; display: none; align-items: center; justify-content: center; }
    .modal-overlay.active { display: flex; }
    .modal-box { 
        background: #fff; border-radius: 8px; width: 680px; 
        max-height: 90vh; display: flex; flex-direction: column; overflow: hidden; /* Prevent body scroll */
        box-shadow: 0 10px 40px rgba(0,0,0,0.2); 
    }
    .modal-header { 
        background: #1a5276; color: #fff; padding: 12px 20px; /* Reduced padding */
        display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
    }
    .modal-header h3 { margin: 0; font-size: 0.95rem; font-weight: 600; }
    .modal-close { background: none; border: none; color: #fff; font-size: 1.1rem; cursor: pointer; padding: 2px 8px; }
    
    .modal-body { 
        padding: 15px 20px; /* Reduced padding */
        overflow-y: auto; flex: 1; /* Allow scroll only here */
    }

    .detail-section { margin-bottom: 12px; } 
    .detail-section .ds-title { font-size: 0.8rem; border-bottom: 2px solid #2471a3; padding-bottom: 6px; margin-bottom: 10px; font-weight: 700; color: #1a5276; }
    
    .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 20px; }
    /* Fix: Explicit flex-direction to prevent inline label/span issue */
    .detail-item { display: flex; flex-direction: column; }
    .detail-item label { font-size: 0.75rem; color: #666; font-weight: 700; margin-bottom: 3px; text-transform: uppercase; letter-spacing: 0.3px; }
    .detail-item span { font-size: 0.9rem; color: #333; font-weight: 500; border-bottom: 1px dotted #eee; padding-bottom: 2px; }

    .emp-detail-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px 16px; }
    .emp-detail-item { display: flex; flex-direction: column; }
    .emp-detail-item label { font-size: 0.75rem; color: #666; font-weight: 700; margin-bottom: 3px; }
    .emp-detail-item span { font-size: 0.9rem; color: #333; font-weight: 500; }

    .ingreso-notice { background: #fff3cd; border: 1px solid #ffc107; border-radius: 6px; padding: 12px 16px; color: #856404; font-size: 0.85rem; line-height: 1.4; }
    .ingreso-notice i { margin-right: 6px; }

    .modal-actions { 
        display: flex; gap: 8px; justify-content: flex-end; 
        padding: 12px 20px; background: #f9f9f9; border-top: 1px solid #eee; flex-shrink: 0;
        flex-wrap: wrap; /* Allow buttons to wrap */
    }

    /* Modal Cards Specifics */
    .card-periodico { border: 2px solid #8e44ad; color: #8e44ad; }
    .card-periodico.selected { background-color: rgba(142, 68, 173, 0.1); }
    .card-periodico i { color: #8e44ad; }
    
    .card-ingreso { border: 2px solid #16a085; color: #16a085; }
    .card-ingreso.selected { background-color: rgba(22, 160, 133, 0.1); }
    .card-ingreso i { color: #16a085; }

    .card-title { font-weight: 700; font-size: 1rem; margin-top: 10px; text-transform: uppercase; }
    .card-subtitle { font-size: 0.8rem; color: #777; font-weight: normal; margin-top: 5px; }

    .modal-instruction { text-align: center; color: #555; margin-bottom: 20px; font-size: 1rem; }
    .modal-alert { padding: 10px; margin-bottom: 15px; border-radius: 4px; display: none; font-size: 0.85rem; }
    .modal-alert.error { background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    .modal-alert.success { background-color: #d4edda; color: #155724; border: 1px solid #c3e6c3; }

    /* ══════════ Modal de Impresión Embebida ══════════ */
    .print-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 3000; display: none; justify-content: center; align-items: center; backdrop-filter: blur(2px); }
    .print-overlay.active { display: flex; }
    .print-modal { background: #fff; width: 90%; max-width: 900px; height: 85vh; border-radius: 8px; overflow: hidden; display: flex; flex-direction: column; box-shadow: 0 10px 40px rgba(0,0,0,0.3); }
    .print-modal-header { display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; background: #1a5276; color: #fff; }
    .print-modal-header h3 { margin: 0; font-size: 1rem; font-weight: 600; }
    .print-modal-header .pm-actions { display: flex; gap: 8px; }
    .print-modal-header .pm-btn { padding: 7px 18px; border: none; border-radius: 4px; font-size: 0.82rem; font-weight: 600; cursor: pointer; font-family: inherit; }
    .pm-btn-print { background: #27ae60; color: #fff; }
    .pm-btn-print:hover { background: #1e8449; }
    .pm-btn-close { background: rgba(255,255,255,0.2); color: #fff; }
    .pm-btn-close:hover { background: rgba(255,255,255,0.3); }
    .print-iframe { flex: 1; border: none; width: 100%; }

    /* ══════════ Paginación ══════════ */
    .paginacion { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 14px 0; }
    .paginacion button { padding: 6px 14px; font-size: 0.8rem; font-weight: 600; border: 1px solid #d0d0d0; border-radius: 4px; background: #fff; color: #333; cursor: pointer; font-family: inherit; transition: all 0.15s; }
    .paginacion button:hover:not(:disabled) { background: #2471a3; color: #fff; border-color: #2471a3; }
    .paginacion button:disabled { opacity: 0.4; cursor: default; }
    .paginacion .pag-info { font-size: 0.82rem; color: #555; font-weight: 500; }

    /* Menu Contextual */
    .ctx-menu { 
        display: none; 
        position: absolute; 
        background: #fff; 
        box-shadow: 0 5px 15px rgba(0,0,0,0.2); 
        border: 1px solid #ddd; 
        border-radius: 4px; 
        z-index: 10000; 
        min-width: 150px;
        font-family: 'Inter', 'Segoe UI', sans-serif;
    }
    .ctx-menu-item { 
        padding: 10px 15px; 
        cursor: pointer; 
        font-size: 0.85rem; 
        color: #333; 
        display: flex; 
        align-items: center; 
        gap: 8px; 
        text-decoration: none; 
        transition: background 0.1s;
    }
    .ctx-menu-item:hover { background: #f0f8ff; color: #1a5276; }
    .ctx-menu-item i { color: #555; width: 16px; text-align: center; font-size: 1rem; }
</style>

<div class="sm-container">
    <div class="sm-header">
        <h2><i class="fas fa-stethoscope"></i> Servicio M&eacute;dico</h2>
        <span style="font-size: 0.75rem; color: rgba(255,255,255,0.7);">M&oacute;dulo de Servicios M&eacute;dicos</span>
    </div>

    <!-- Filtros -->
    <div class="sm-filtros">
        <div class="filtros-title"><i class="fas fa-filter"></i> Filtros de B&uacute;squeda</div>
        <div class="filtros-row">
            <div class="filtro-group">
                <label>No. Empleado</label>
                <input type="number" id="filtroNumEmp" placeholder="Ej: 1001" />
            </div>
            <div class="filtro-group">
                <label>Tipo Solicitud</label>
                <select id="filtroModalidad">
                    <option value="">Todos</option>
                    <option value="PERIODICO">Peri&oacute;dico</option>
                    <option value="INGRESO">Nuevo Ingreso</option>
                </select>
            </div>
            <div class="filtro-group">
                <label>Estatus</label>
                <select id="filtroEstatus">
                    <option value="">Todos</option>
                    <option value="PENDIENTE">Pendiente</option>
                    <option value="EN PROCESO">En Proceso</option>
                    <option value="COMPLETADA">Completada</option>
                </select>
            </div>
            <div class="filtro-group">
                <label>Fecha Desde</label>
                <input type="date" id="filtroFechaDesde" />
            </div>
            <div class="filtro-group">
                <label>Fecha Hasta</label>
                <input type="date" id="filtroFechaHasta" />
            </div>
            <div class="filtro-group" style="flex-direction:row; gap:6px; flex:0 0 auto; align-items:flex-end;">
                <button class="btn-filtrar" onclick="aplicarFiltros()"><i class="fas fa-search"></i> Buscar</button>
                <button class="btn-limpiar" onclick="limpiarFiltros()"><i class="fas fa-times"></i> Limpiar</button>
            </div>
        </div>
    </div>
    
    <!-- Tabla de solicitudes -->
    <div class="sm-panel">
        <div class="sp-title">
            <span><i class="fas fa-inbox"></i> Bandeja de Solicitudes</span>
            <button class="btn-gci btn-gci-secondary btn-gci-sm" onclick="cargarSolicitudes()"><i class="fas fa-sync-alt"></i> Actualizar</button>
        </div>
        <div class="resultados-info" id="resultsInfo"></div>
        <table class="sm-table">
            <thead>
                <tr>
                    <th>Folio</th>
                    <th>Fecha</th>
                    <th>Modalidad</th>
                    <th>Persona</th>
                    <th>No. Emp.</th>
                    <th>Tipo Servicio</th>
                    <th>Proyecto</th>
                    <th>Estatus</th>
                    <th style="text-align:center;">Acciones</th>
                </tr>
            </thead>
            <tbody id="tbodySolicitudes">
                <tr><td colspan="9" class="no-data">Cargando solicitudes...</td></tr>
            </tbody>
        </table>
        <div id="paginacionControles" class="paginacion"></div>
    </div>
</div>
</div>

<!-- ══════════ Modal de Impresión Embebida ══════════ -->
<div class="print-overlay" id="printOverlay">
    <div class="print-modal">
        <div class="print-modal-header">
            <h3><i class="fas fa-print"></i> Vista Previa de Impresi&oacute;n</h3>
            <div class="pm-actions">
                <button class="pm-btn pm-btn-print" onclick="imprimirIframeReal()"><i class="fas fa-print"></i> Imprimir</button>
                <button class="pm-btn pm-btn-close" onclick="cerrarImpresion()"><i class="fas fa-times"></i> Cerrar</button>
            </div>
        </div>
        <iframe id="printIframe" class="print-iframe"></iframe>
    </div>
</div>

<!-- Menú Contextual Flotante -->
<div id="ctxMenu" class="ctx-menu">
    <a href="#" id="ctxEvaluar" class="ctx-menu-item">
        <i class="fas fa-notes-medical" style="color:#16a085;"></i> Evaluar Solicitud
    </a>
    <a href="#" id="ctxEliminar" class="ctx-menu-item">
        <i class="fas fa-trash-alt" style="color:#c0392b;"></i> Eliminar Solicitud
    </a>
</div>
<!-- ══════════ Modal de Detalle ══════════ -->
<div class="modal-overlay" id="modalDetalle">
    <div class="modal-box">
        <div class="modal-header">
            <h3><i class="fas fa-file-medical-alt"></i> Detalle de Solicitud &mdash; <span id="modalFolio"></span></h3>
            <button class="modal-close" onclick="cerrarModal()"><i class="fas fa-times"></i></button>
        </div>
        <div class="modal-body">
            <div class="detail-section">
                <div class="ds-title"><i class="fas fa-info-circle"></i> Informaci&oacute;n de la Solicitud</div>
                <div class="detail-grid">
                    <div class="detail-item"><label>Folio</label><span id="detFolio">&mdash;</span></div>
                    <div class="detail-item"><label>Fecha</label><span id="detFecha">&mdash;</span></div>
                    <div class="detail-item"><label>Modalidad</label><span id="detModalidad">&mdash;</span></div>
                    <div class="detail-item"><label>Tipo de Servicio</label><span id="detTipoServicio">&mdash;</span></div>
                    <div class="detail-item"><label>Estatus Actual</label><span id="detEstatus">&mdash;</span></div>
                    <div class="detail-item"><label>Proyecto</label><span id="detProyecto">&mdash;</span></div>
                </div>
            </div>

            <div class="detail-section" id="seccionEmpleado" style="display:none;">
                <div class="emp-detail-box">
                    <div class="edb-title"><i class="fas fa-user-tie"></i> Datos del Empleado (Pre-llenados)</div>
                    <div class="emp-detail-grid">
                        <div class="emp-detail-item"><label>No. Empleado</label><span id="detEmpNum">&mdash;</span></div>
                        <div class="emp-detail-item"><label>Nombre Completo</label><span id="detEmpNombre">&mdash;</span></div>
                        <div class="emp-detail-item"><label>CURP</label><span id="detEmpCurp">&mdash;</span></div>
                        <div class="emp-detail-item"><label>RFC</label><span id="detEmpRfc">&mdash;</span></div>
                        <div class="emp-detail-item"><label>NSS</label><span id="detEmpNss">&mdash;</span></div>
                        <div class="emp-detail-item"><label>Puesto</label><span id="detEmpPuesto">&mdash;</span></div>
                        <div class="emp-detail-item"><label>Proyecto</label><span id="detEmpProyecto">&mdash;</span></div>
                    </div>
                </div>
            </div>

            <div class="detail-section" id="seccionIngreso" style="display:none;">
                <div class="ingreso-notice">
                    <i class="fas fa-exclamation-triangle"></i>
                    <strong>Nuevo Ingreso:</strong> Esta solicitud es para un candidato nuevo. No existen datos previos en el sistema, el personal m&eacute;dico deber&aacute; completar toda la informaci&oacute;n durante la evaluaci&oacute;n.
                </div>
                <div style="margin-top: 10px;">
                    <div class="detail-grid">
                        <div class="detail-item"><label>Candidato</label><span id="detCandNombre">&mdash;</span></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-actions" id="modalActions">
            <button class="btn-gci btn-gci-secondary" id="btnPrintSol" style="display:none;" onclick="abrirImpresion(this.dataset.url)"><i class="fas fa-print"></i> Imprimir Solicitud</button>
            <button class="btn-gci btn-gci-secondary" id="btnPrintEval" style="display:none;" onclick="abrirImpresion(this.dataset.url)"><i class="fas fa-file-medical"></i> Imprimir Evaluaci&oacute;n</button>
            <button class="btn-gci btn-gci-secondary" id="btnPrintAnti" style="display:none;" onclick="abrirImpresion(this.dataset.url)"><i class="fas fa-flask"></i> Imprimir Antidoping</button>
            <a href="#" id="btnIrEvaluar" class="btn-gci btn-gci-primary" style="display:none;"><i class="fas fa-notes-medical"></i> Ir a Evaluaci&oacute;n</a>
            <div style="flex:1;"></div>
            <button class="btn-gci btn-gci-secondary" onclick="cerrarModal()">Cerrar</button>
            <button class="btn-gci btn-gci-danger" id="btnEliminar" onclick="eliminarSolicitud()"><i class="fas fa-trash-alt"></i> Eliminar</button>
        </div>
    </div>
</div>

@section scripts {
<!-- Modal de Impresión Embebida -->
<div class="print-overlay" id="printOverlay">
    <div class="print-modal">
        <div class="print-modal-header">
            <h3><i class="fas fa-print"></i> Vista Previa de Impresi&oacute;n</h3>
            <div class="pm-actions">
                <button class="pm-btn pm-btn-print" onclick="imprimirDesdeIframe()"><i class="fas fa-print"></i> Imprimir</button>
                <button class="pm-btn pm-btn-close" onclick="cerrarImpresion()"><i class="fas fa-times"></i> Cerrar</button>
            </div>
        </div>
        <iframe id="printIframe" class="print-iframe"></iframe>
    </div>
</div>
<script>
    var currentOrdenId = null;
    var paginaActual = 1;
    var registrosPorPagina = 10;
    var datosFiltrados = [];
    var todosLosTiposServicio = [];
    var catalogosCargados = false;

    $(document).ready(function () {
        cargarInicial();

        // Ocultar menú al hacer clic en cualquier lado
        $(document).on('click', function() { $('#ctxMenu').hide(); });

        // Evento Context Menu (Click Derecho)
        $('#tbodySolicitudes').on('contextmenu', 'tr', function(e) {
            var pk = $(this).data('pk');
            var status = $(this).data('status') || '';
            var statusLower = status.toLowerCase();
            
            // Si está completa, previene menú default y no muestra nada
            if (statusLower.indexOf('complet') >= 0) {
                return; 
            }
            
            if(!pk) return;

            e.preventDefault(); // Prevenir menú del navegador
            
            var evalUrl = '@Url.Action("IniciarEvaluacion", "ServicioMedico")/' + pk;
            $('#ctxEvaluar').attr('href', evalUrl);
            
            // Mostrar Eliminar solo si es Pendiente (no proceso, no completa)
            // Asumimos que si no es proceso ni completa, es pendiente
            var isProceso = statusLower.indexOf('proceso') >= 0;
            
            if (!isProceso) {
                $('#ctxEliminar').show().off('click').on('click', function() {
                    if(confirm('\u00bfEst\u00e1 seguro de eliminar esta solicitud?')) {
                        doEliminar(pk, false);
                        $('#ctxMenu').hide();
                    }
                });
            } else {
                $('#ctxEliminar').hide();
            }
            
            $('#ctxMenu').css({ top: e.pageY, left: e.pageX }).show();
        });
    });

    // Carga inicial combinada: solicitudes + catálogos en 1 sola llamada HTTP
    function cargarInicial() {
        $.getJSON('@Url.Action("CargarInicial", "ServicioMedico")', function (resp) {
            if (resp.success) {
                todasLasSolicitudes = resp.data;
                aplicarFiltros();
            } else {
                $('#tbodySolicitudes').html('<tr><td colspan="9" class="no-data">Error al cargar datos.</td></tr>');
            }
        });
    }

    // Recarga solo solicitudes (después de crear/eliminar)
    function cargarSolicitudes() {
        $.getJSON('@Url.Action("ObtenerSolicitudes", "ServicioMedico")', function (resp) {
            if (resp.success) {
                todasLasSolicitudes = resp.data;
                aplicarFiltros();
            } else {
                $('#tbodySolicitudes').html('<tr><td colspan="9" class="no-data">Error al cargar solicitudes.</td></tr>');
            }
        });
    }

    function aplicarFiltros() {
        var filtroEmp = $('#filtroNumEmp').val() ? parseInt($('#filtroNumEmp').val()) : null;
        var filtroMod = $('#filtroModalidad').val();
        var filtroEst = $('#filtroEstatus').val();
        var filtroDesde = $('#filtroFechaDesde').val();
        var filtroHasta = $('#filtroFechaHasta').val();

        var filtradas = todasLasSolicitudes.filter(function (s) {
            // Filtro por número de empleado
            if (filtroEmp && s.FkEmpleado !== filtroEmp) return false;
            // Filtro por modalidad
            if (filtroMod && s.Modalidad !== filtroMod) return false;
            
            // Filtro por estatus
            if (filtroEst) {
                var estLow = (s.EstatusDesc || '').toUpperCase();
                // We use includes instead of direct equality since sometimes the DB might say "COMPLETADO" or "COMPLETADAS"
                if (estLow.indexOf(filtroEst) < 0) return false;
            }
            
            if (filtroDesde && s.FechaOrdenFormateada) {
                var fechaSol = parseFecha(s.FechaOrdenFormateada);
                if (fechaSol && fechaSol < new Date(filtroDesde)) return false;
            }

            if (filtroHasta && s.FechaOrdenFormateada) {
                var fechaSol2 = parseFecha(s.FechaOrdenFormateada);
                var hasta = new Date(filtroHasta);
                hasta.setHours(23, 59, 59);
                if (fechaSol2 && fechaSol2 > hasta) return false;
            }

            return true;
        });



        // Ordenar: Pendiente (1) -> Proceso (2) -> Completada (3)
        filtradas.sort(function(a, b) {
            function getWeight(s) {
                var d = (s.EstatusDesc || '').toLowerCase();
                if (d.indexOf('complet') >= 0) return 3;
                if (d.indexOf('proceso') >= 0) return 2;
                return 1; // Pendiente
            }
            return getWeight(a) - getWeight(b);
        });

        renderTabla(filtradas);
    }

    function parseFecha(fechaStr) {
        if (!fechaStr) return null;
        var partes = fechaStr.split(' ');
        var fecha = partes[0].split('/');
        if (fecha.length === 3) {
            return new Date(fecha[2], fecha[1] - 1, fecha[0]);
        }
        return new Date(fechaStr);
    }

    function renderTabla(data) {
        datosFiltrados = data;
        paginaActual = 1;
        renderPagina();
    }

    function renderPagina() {
        var $tbody = $('#tbodySolicitudes');
        var totalPaginas = Math.max(1, Math.ceil(datosFiltrados.length / registrosPorPagina));
        if (paginaActual > totalPaginas) paginaActual = totalPaginas;

        var inicio = (paginaActual - 1) * registrosPorPagina;
        var fin = Math.min(inicio + registrosPorPagina, datosFiltrados.length);
        var pagina = datosFiltrados.slice(inicio, fin);

        if (datosFiltrados.length > 0) {
            $('#resultsInfo').text('Mostrando ' + (inicio + 1) + '-' + fin + ' de ' + datosFiltrados.length + ' solicitudes.');

            var html = [];
            for (var i = 0; i < pagina.length; i++) {
                var s = pagina[i];
                var badgeMod = s.Modalidad === 'PERIODICO'
                    ? '<span class="badge-sm badge-periodico">Peri\u00f3dico</span>'
                    : '<span class="badge-sm badge-ingreso">Ingreso</span>';
                var estLow = (s.EstatusDesc || '').toLowerCase();
                var badgeEst = 'badge-pendiente';
                if (estLow.indexOf('proceso') >= 0) badgeEst = 'badge-proceso';
                if (estLow.indexOf('complet') >= 0) badgeEst = 'badge-completado';
                var numEmp = s.FkEmpleado ? s.FkEmpleado : '-';
                var evalUrl = '@Url.Action("IniciarEvaluacion", "ServicioMedico")/' + s.PkOrdenMedico;

                html.push(
                    '<tr data-pk="' + s.PkOrdenMedico + '" data-status="' + (s.EstatusDesc || '') + '" style="cursor:pointer;">' +
                    '<td><strong>' + s.FolioDisplay + '</strong></td>' +
                    '<td>' + s.FechaOrdenFormateada + '</td>' +
                    '<td>' + badgeMod + '</td>' +
                    '<td>' + (s.NombrePersona || '-') + '</td>' +
                    '<td>' + numEmp + '</td>' +
                    '<td>' + (s.TipoServicioDesc || '-') + '</td>' +
                    '<td>' + (s.ProyectoDesc || '-') + '</td>' +
                    '<td><span class="badge-sm ' + badgeEst + '">' + (s.EstatusDesc || 'Pendiente') + '</span></td>' +
                    '<td style="text-align:center;">' +
                    '<div class="row-actions">' +
                    '<button class="row-btn row-btn-ver" onclick="event.stopPropagation(); verDetalle(' + s.PkOrdenMedico + ')"><i class="fas fa-eye"></i> Ver</button>' +
                    '</div>' +
                    '</td>' +
                    '</tr>'
                );
            }
            $tbody.html(html.join(''));
        } else {
            $tbody.html('<tr><td colspan="9" class="no-data">No se encontraron solicitudes con los filtros aplicados.</td></tr>');
            $('#resultsInfo').text('0 resultados.');
        }

        // Paginación controles
        var pagHtml = '<button ' + (paginaActual <= 1 ? 'disabled' : '') + ' onclick="cambiarPagina(-1)">&laquo; Anterior</button>' +
                      '<span class="pag-info">P\u00e1gina ' + paginaActual + ' de ' + totalPaginas + '</span>' +
                      '<button ' + (paginaActual >= totalPaginas ? 'disabled' : '') + ' onclick="cambiarPagina(1)">Siguiente &raquo;</button>';
        $('#paginacionControles').html(pagHtml);

        // Delegated row click
        $tbody.off('click', 'tr').on('click', 'tr[data-pk]', function() {
            var pk = $(this).data('pk');
            if(pk) verDetalle(pk);
        });
    }

    function cambiarPagina(dir) {
        paginaActual += dir;
        renderPagina();
    }

    function limpiarFiltros() {
        $('#filtroNumEmp').val('');
        $('#filtroModalidad').val('');
        $('#filtroEstatus').val('');
        $('#filtroFechaDesde').val('');
        $('#filtroFechaHasta').val('');
        aplicarFiltros();
    }

    function verDetalle(pkOrden) {
        currentOrdenId = pkOrden;

        $.getJSON('@Url.Action("VerDetalle", "ServicioMedico")', { id: pkOrden }, function (resp) {
            if (!resp.success) {
                alert(resp.message);
                return;
            }

            var o = resp.orden;
            $('#modalFolio').text(o.FolioDisplay);
            $('#detFolio').text(o.FolioDisplay);
            $('#detFecha').text(o.FechaOrdenFormateada);
            $('#detModalidad').text(o.Modalidad === 'PERIODICO' ? 'Examen Peri\u00f3dico' : 'Nuevo Ingreso');
            $('#detTipoServicio').text(o.TipoServicioDesc || '-');
            $('#detEstatus').text(o.EstatusDesc || 'Pendiente');
            $('#detProyecto').text(o.ProyectoDesc || '-');

            if (o.Modalidad === 'PERIODICO' && resp.empleado) {
                var emp = resp.empleado;
                $('#detEmpNum').text(emp.PkEmpleado);
                $('#detEmpNombre').text(emp.NombreCompleto || '-');
                $('#detEmpCurp').text(emp.Curp || '-');
                $('#detEmpRfc').text(emp.Rfc || '-');
                $('#detEmpNss').text(emp.Nss || '-');
                $('#detEmpPuesto').text(emp.PuestoDesc || '-');
                $('#detEmpProyecto').text(emp.ProyectoDesc || '-');
                $('#seccionEmpleado').show();
                $('#seccionIngreso').hide();
            } else {
                $('#detCandNombre').text(o.NombrePersona || '-');
                $('#seccionEmpleado').hide();
                $('#seccionIngreso').show();
            }

            // Reset all action buttons
            $('#btnPrintSol').hide();
            $('#btnPrintEval').hide();
            $('#btnPrintAnti').hide();
            $('#btnIrEvaluar').hide();
            $('#btnEliminar').hide();

            var estLow = (o.EstatusDesc || '').toLowerCase();
            var evalUrl = '@Url.Action("IniciarEvaluacion", "ServicioMedico")/' + o.PkOrdenMedico;

            if (estLow.indexOf('complet') >= 0) {
                // Completada: show all print buttons
                $('#btnPrintSol').attr('data-url', '@Url.Action("ImprimirSolicitud", "ServicioMedico")/' + o.PkOrdenMedico).show();
                $('#btnPrintEval').attr('data-url', '@Url.Action("ImprimirEvaluacion", "ServicioMedico")/' + o.PkOrdenMedico).show();
                $('#btnPrintAnti').attr('data-url', '@Url.Action("ImprimirAntidoping", "ServicioMedico")/' + o.PkOrdenMedico).show();
                $('#btnPrintAnti').attr('data-url', '@Url.Action("ImprimirAntidoping", "ServicioMedico")/' + o.PkOrdenMedico).show();
                // $('#btnIrEvaluar').attr('href', evalUrl).show(); // Comentado por solicitud: no volver a evaluar si ya está completa
            } else if (estLow.indexOf('proceso') >= 0) {
                // En Proceso: can evaluate or delete
                $('#btnIrEvaluar').attr('href', evalUrl).show();
                $('#btnEliminar').show();
            } else {
                // Pendiente: can start or delete
                $('#btnIrEvaluar').attr('href', evalUrl).show();
                $('#btnEliminar').show();
            }

            $('#modalDetalle').addClass('active');
        });
    }

    function cambiarEstatus(nuevoEstatus) {
        if (!currentOrdenId) return;

        var textoEstatus = nuevoEstatus === 2 ? 'En Proceso' : 'Completada';
        if (!confirm('\u00bfCambiar la solicitud a "' + textoEstatus + '"?')) return;

        $.ajax({
            url: '@Url.Action("CambiarEstatus", "ServicioMedico")',
            type: 'POST',
            data: { pkOrdenMedico: currentOrdenId, fkEstatus: nuevoEstatus },
            success: function (resp) {
                if (resp.success) {
                    cerrarModal();
                    cargarSolicitudes();
                } else {
                    alert(resp.message);
                }
            },
            error: function () {
                alert('Error de conexi\u00f3n.');
            }
        });
    }

    function cerrarModal() {
        $('#modalDetalle').removeClass('active');
        currentOrdenId = null;
    }

    function eliminarSolicitud() {
        if (!currentOrdenId) return;
        if (!confirm('\u00bfEst\u00e1 seguro de eliminar esta solicitud? Esta acci\u00f3n no se puede deshacer.')) return;
        doEliminar(currentOrdenId, true);
    }

    function doEliminar(pk, fromModal) {
        $.ajax({
            url: '@Url.Action("Eliminar", "ServicioMedico")',
            type: 'POST',
            data: { pkOrdenMedico: pk },
            success: function (resp) {
                if (resp.success) {
                    if(fromModal) cerrarModal();
                    cargarSolicitudes();
                } else {
                    alert(resp.message);
                }
            },
            error: function () {
                alert('Error de conexi\u00f3n.');
            }
        });
    }

    // ═══════ Funciones de Impresión Embebida ═══════
    function abrirImpresion(url) {
        if (!url) return;
        
        // Cierra el modal de detalle para que no se empalme con el de impresión
        if ($('#modalDetalle').hasClass('active')) {
            cerrarModal();
        }

        $('#printIframe').attr('src', url);
        $('#printOverlay').addClass('active');
    }

    function cerrarImpresion() {
        $('#printOverlay').removeClass('active');
        $('#printIframe').attr('src', 'about:blank');
    }

    function imprimirIframeReal() {
        var iframe = document.getElementById('printIframe');
        if (iframe && iframe.contentWindow) {
            iframe.contentWindow.print();
        }
    }

    $(document).on('click', '.modal-overlay', function (e) {
        if ($(e.target).hasClass('modal-overlay')) {
            // Check ID to distinguish modals
            if(e.target.id === 'modalNuevaSolicitud') cerrarNuevaSolicitud();
            else cerrarModal();
        }
    });

    // Cerrar modal de impresión al hacer clic en el overlay
    $('#printOverlay').on('click', function(e) {
        if ($(e.target).is('#printOverlay')) cerrarImpresion();
    });

</script>
}
